                      <MeasureName>Bullet_Optimal</MeasureName>
                      <UniqueName>[Measures].[Bullet_Optimal]</UniqueName>
                    </ID>
                    <ItemCaption>Bullet_Optimal</ItemCaption>
                  </Item>
