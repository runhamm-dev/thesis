                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[u_Rth_Combined]</ColumnName>
                    </ID>
                    <ItemCaption>u_Rth_Combined</ItemCaption>
                  </Item>
                </Items>
              </Select>
              <AutoExecute>false</AutoExecute>
              <From>Model</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE
ADDCOLUMNS(
    SUMMARIZE(
        CALCULATETABLE(Dim_Tests, Dim_Tests[RunNumber] = 1),
        Dim_Tests[ColdPlate_ID],
        Dim_Tests[Test_ID],
        Dim_Tests[FlowRate_Lpm],
        Dim_Tests[InletSetpoint_C],
        Dim_Tests[RunNumber]
    ),
    "Rth_SS",           0 + CALCULATE(MAX(Fact_TestSummary[Rth_SS])),
    "Power_SS",         0 + CALCULATE(MAX(Fact_TestSummary[Power_SS])),
    "Q_SS",             0 + CALCULATE(MAX(Fact_TestSummary[Q_SS])),
    "Efficiency_SS",    0 + CALCULATE(MAX(Fact_TestSummary[Efficiency_SS])),
    "Tj_SS",            0 + CALCULATE(MAX(Fact_TestSummary[Tj_SS])),
    "Tin_SS",           0 + CALCULATE(MAX(Fact_TestSummary[Tin_SS])),
    "Tout_SS",          0 + CALCULATE(MAX(Fact_TestSummary[Tout_SS])),
    "TCores_Mean_SS",   0 + CALCULATE(MAX(Fact_TestSummary[TCores_Mean_SS])),
    "TCores_Min_SS",    0 + CALCULATE(MAX(Fact_TestSummary[TCores_Min_SS])),
    "TCores_Max_SS",    0 + CALCULATE(MAX(Fact_TestSummary[TCores_Max_SS])),
    "UA_SS",            0 + CALCULATE(MAX(Fact_TestSummary[UA_SS])),
    "LMTD_SS",          0 + CALCULATE(MAX(Fact_TestSummary[LMTD_SS])),
    "ValidTest_Int",    CALCULATE(MAXX(Fact_TestSummary, IF(Fact_TestSummary[ValidTest], 1, 0))),
    "dP_ColdPlate_SS", 0 + CALCULATE(MAX(Fact_TestSummary[dP_ColdPlate_SS])),
    "W_Hydraulic_SS",  0 + CALCULATE(MAX(Fact_TestSummary[W_Hydraulic_SS])),
    "u_Rth_Combined",  0 + CALCULATE(MAX(Fact_TestSummary[u_Rth_Combined])),
    "u_dP_SS",         0 + CALCULATE(MAX(Fact_TestSummary[u_dP_SS])),
    "u_W_Hydraulic_SS",0 + CALCULATE(MAX(Fact_TestSummary[u_W_Hydraulic_SS]))
)
</Statement>
              <ParameterDefinitions />
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>EVALUATE
ADDCOLUMNS(
    SUMMARIZE(
        CALCULATETABLE(Dim_Tests, Dim_Tests[RunNumber] = 1),
        Dim_Tests[ColdPlate_ID],
