    <DataSet Name="DS_ColdPlateInfo">
      <Query>
        <DataSourceName>MyWorkspace_V3</DataSourceName>
        <rd:DesignerState>
          <QueryDefinition xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/AnalysisServices/QueryDefinition">
            <CommandType>DAX</CommandType>
            <Type>Query</Type>
            <QuerySpecification xsi:type="MDXQuerySpecification">
              <Select>
                <Items>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[ColdPlate_ID]</ColumnName>
                    </ID>
                    <ItemCaption>ColdPlate_ID</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[Manufacturer]</ColumnName>
                    </ID>
                    <ItemCaption>Manufacturer</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[Model]</ColumnName>
                    </ID>
                    <ItemCaption>Model</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[FinType]</ColumnName>
                    </ID>
                    <ItemCaption>FinType</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[Material]</ColumnName>
                    </ID>
                    <ItemCaption>Material</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[Mass_g]</ColumnName>
                    </ID>
                    <ItemCaption>Mass_g</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[DesignIteration]</ColumnName>
                    </ID>
                    <ItemCaption>DesignIteration</ItemCaption>
                  </Item>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[MountingHardware]</ColumnName>
                    </ID>
                    <ItemCaption>MountingHardware</ItemCaption>
                  </Item>
                </Items>
              </Select>
              <AutoExecute>false</AutoExecute>
              <From>Model</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE
VAR _tp = DISTINCT(Dim_Tests[ColdPlate_ID])
RETURN
SELECTCOLUMNS(
    FILTER(Dim_ColdPlates, Dim_ColdPlates[ColdPlate_ID] IN _tp),
    "ColdPlate_ID",      Dim_ColdPlates[ColdPlate_ID],
    "Manufacturer",      Dim_ColdPlates[Manufacturer],
    "Model",             Dim_ColdPlates[Model],
    "FinType",           Dim_ColdPlates[FinType],
    "Material",          Dim_ColdPlates[Material],
    "Mass_g",            Dim_ColdPlates[Mass_g],
    "DesignIteration",   Dim_ColdPlates[DesignIteration],
    "MountingHardware",  Dim_ColdPlates[MountingHardware]
)</Statement>
              <ParameterDefinitions />
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>EVALUATE
VAR _tp = DISTINCT(Dim_Tests[ColdPlate_ID])
RETURN
SELECTCOLUMNS(
    FILTER(Dim_ColdPlates, Dim_ColdPlates[ColdPlate_ID] IN _tp),
    "ColdPlate_ID",      Dim_ColdPlates[ColdPlate_ID],
    "Manufacturer",      Dim_ColdPlates[Manufacturer],
    "Model",             Dim_ColdPlates[Model],
    "FinType",           Dim_ColdPlates[FinType],
    "Material",          Dim_ColdPlates[Material],
    "Mass_g",            Dim_ColdPlates[Mass_g],
    "DesignIteration",   Dim_ColdPlates[DesignIteration],
    "MountingHardware",  Dim_ColdPlates[MountingHardware]
)</CommandText>
      </Query>
