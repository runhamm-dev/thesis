              <From>Model</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE
ADDCOLUMNS(
    VALUES(Dim_Tests[ColdPlate_ID]),
    "Bullet_1",       [Bullet_1],
    "Bullet_2",       [Bullet_2],
    "Bullet_4",       [Bullet_4],
    "Bullet_Optimal", [Bullet_Optimal]
)</Statement>
              <ParameterDefinitions />
            </Query>
