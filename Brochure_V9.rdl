    <DataSet Name="DS_ColdPlateList">
      <Query>
        <DataSourceName>MyWorkspace_V3</DataSourceName>
        <rd:DesignerState>
          <QueryDefinition xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/AnalysisServices/QueryDefinition">
            <CommandType>DAX</CommandType>
            <Type>Query</Type>
            <QuerySpecification xsi:type="MDXQuerySpecification">
              <Select>
                <Items>
                  <Item>
                    <ID xsi:type="Column">
                      <ColumnName>[ColdPlate_ID]</ColumnName>
                    </ID>
                    <ItemCaption>ColdPlate_ID</ItemCaption>
                  </Item>
                </Items>
              </Select>
              <AutoExecute>false</AutoExecute>
              <From>Model</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE
SELECTCOLUMNS(
    Dim_ColdPlates,
    "ColdPlate_ID", Dim_ColdPlates[ColdPlate_ID]
)
ORDER BY [ColdPlate_ID]
</Statement>
              <ParameterDefinitions />
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>EVALUATE
SELECTCOLUMNS(
    Dim_ColdPlates,
    "ColdPlate_ID", Dim_ColdPlates[ColdPlate_ID]
)
ORDER BY [ColdPlate_ID]</CommandText>
      </Query>
