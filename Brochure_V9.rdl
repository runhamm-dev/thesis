          <Textbox Name="IntroText">
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="The " &amp; First(Fields!ColdPlate_ID.Value, "DS_ColdPlateInfo") &amp; " is a high-performance liquid cooling solution designed for efficient heat transfer on " &amp; First(Fields!Socket.Value, "DS_CPUInfo") &amp; " socket processors. Thermal-hydraulic performance was characterised on a live " &amp; First(Fields!Manufacturer.Value, "DS_CPUInfo") &amp; " " &amp; First(Fields!CPU_Model.Value, "DS_CPUInfo") &amp; " processor under sustained fixed-frequency stress of 4.9 GHz, with an average total power to the CPU cores of " &amp; Format(Avg(Fields!Power_SS.Value, "DS_PerformanceByFlow"), "0") &amp; " W. Tests were performed across flow rates up to " &amp; Format(Max(Fields!FlowRate_Lpm.Value, "DS_PerformanceByFlow"), "0.0") &amp; " L/min at a fixed coolant inlet temperature of " &amp; First(Fields!InletSetpoint_C.Value, "DS_PerformanceByFlow") &amp; "°C."</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
