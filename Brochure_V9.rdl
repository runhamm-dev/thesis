              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE
VAR _testedCPUs = DISTINCT(Dim_Tests[CPU_Model])
RETURN
SELECTCOLUMNS(
    FILTER(Dim_CPUs, Dim_CPUs[CPU_Model] IN _testedCPUs),
    "CPU_Model",        Dim_CPUs[CPU_Model],
    "Manufacturer",     Dim_CPUs[Manufacturer],
    "Generation",       Dim_CPUs[Generation],
    "P_Cores",          Dim_CPUs[P_Cores],
    "E_Cores",          Dim_CPUs[E_Cores],
    "TDP_W",            Dim_CPUs[TDP_W],
    "TjMax_C",          Dim_CPUs[TjMax_C],
    "Socket",           Dim_CPUs[Socket],
    "StressFreq_GHz",   Dim_CPUs[StressFreq_GHz]
)</Statement>
              <ParameterDefinitions />
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>EVALUATE
VAR _testedCPUs = DISTINCT(Dim_Tests[CPU_Model])
RETURN
SELECTCOLUMNS(
